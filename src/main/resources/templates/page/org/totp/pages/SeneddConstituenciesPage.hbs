<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <title>Top of the Poops | Constituencies</title>
    <meta name="description" content="Find how much sewage was dumped in your constituency in {{year}}">

    {{> chunks/favicons }}
    {{> chunks/meta-styles }}
    {{> chunks/meta-scripts }}

    {{> components/meta-opengraph title="Senedd Constituencies"
        description=(concat "Find how much sewage was dumped in your constituency in " year)
    }}

    <style>
        #map-constituency {
            position: fixed;
            inset: 0;
            z-index: -1;

            opacity: 0.08;           /* fade it out */
            pointer-events: none;    /* map won't intercept clicks */

            display: flex;
            justify-content: center;
            align-items: center;
        }

        #map-constituency svg {
            width: 100vw;
            height: 90vh;
        }
    </style>
</head>
<body>
{{> chunks/navbar }}

<div id="map-constituency"></div>

<div class="container">
    <div class="row">
        <div class="col">
            <p class="display-4">Find your constituency & take action</p>
        </div>
    </div>
    <div class="row">
        <div class="col">
            {{#> components/section title=(concat "Constituencies Ranked for " year)}}

                <p>Here are all the Senedd constituencies in Wales that had sewage overflows in 2024</p>

                <p><b>Click</b> on the constituency name to see more details...</p>

                {{> chunks/plea }}

                <div class="table-responsive">
                    <table id="table-constituency" data-id="constituency" class="table table-spills table-striped">
                        <thead>
                        <tr>
                            <td>Rank</td>
                            <td>Constituency</td>
                            <td>Sewage Dumps</td>
                            <td>Change</td>
                            <td>Duration (Hours)</td>
                            <td>Duration</td>
                            <td>Change</td>
                        </tr>
                        </thead>
                        <tbody>
                        {{#each rankings}}
                            <tr>
                                <td>{{this.rank}}</td>
                                <td><a href="{{this.constituency.uri}}">{{this.constituency.name}}</a></td>
                                <td data-sort="{{this.count.count}}">{{numberFormat this.count.count}}</td>
                                <td class="align-middle {{>components/class-delta this.countDelta}}">{{numberFormat
                                        this.countDelta.value}}</td>
                                <td data-sort={{this.duration.hours}}>{{numberFormat this.duration.hours}}</td>
                                <td data-sort={{this.duration.hours}}>{{this.duration.explain}}</td>
                                <td class="align-middle {{>components/class-delta this.durationDelta}}">{{numberFormat
                                        this.durationDelta.hours}}</td>
                            </tr>
                        {{/each}}
                        </tbody>
                    </table>
                </div>
            {{/components/section}}
        </div>
    </div>
</div>

<script type="module">

    import * as Plot from "/assets/js/plot-0.6.17/plot.esm.js";
    import * as utils from "/assets/js/utils.js";

    const chart = (data) => {
        let constituencyDiv = document.getElementById("map-constituency");

        constituencyDiv.append(
                Plot.plot({
                    projection: {
                        type: "mercator",
                        domain: {
                            type: "MultiPoint",
                            coordinates: [[-5.394287,51.383781], [-2.334595,53.438991]],
                        },
                    },
                    color: {
                        scheme: "oranges",
                    },
                    marks: [
                        Plot.geo(data, {
                            fill: d => d.properties.total_hours,
                            title: d => `${d.properties.constituency}: ${utils.formatNumber(d.properties.total_hours)} hours of sewage`,
                            stroke: "black",
                        }),
                    ]
                }));
    };

    const r = await fetch("/data/v1/{{year}}/geo/choropleth-senedd.json");
    if (r.ok) {
        chart(await r.json())
    }
</script>

<script>
    new DataTable('#table-constituency',
            {
                pageLength: 20,
                dom: "<'row'<'col-md-8'p><'col-md-4'f>>" +
                        "<'row'<'col-sm-12'tr>>" +
                        "<'row'<'col-sm-12 col-md-5'i>>"
            });
</script>

<div class="container">
    <div class="row">
        <div class="col">{{> chunks/data-sources }}</div>
    </div>
</div>

{{> chunks/footer }}
</body>
</html>