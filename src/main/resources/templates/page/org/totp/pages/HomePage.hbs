<script type="module">
    import * as Plot from "/assets/js/plot-0.6.17/plot.esm.js";
    import * as utils from "/assets/js/utils.js"

    const PlotSpillsByIndustryAllTime = (data, width, height) => {

        const sums = Object.entries(
                data.reduce((acc, d) => {
                    acc[d.reporting_year] = (acc[d.reporting_year] || 0) + d.hours;
                    return acc;
                }, {})
        ).map(([year, hours]) => ({
            reporting_year: Number(year),
            hours: hours
        }));

        console.log(sums)

        return Plot.plot({
            marginLeft: 60,
            // marginBottom: 30,
            width: width,
            height: height,
            y: {
                grid: true,
                zero: true,
                label: "Hours of Continuous Dumping ↑",
            },
            color: {
                domain: [false, true],
                range: ["#ccc", "#2f5cd6"]
            },
            x: {
                grid: false,
                domain: [2020, 2021, 2022, 2023, 2024, 2025, 2026],
                tickFormat: d => `${d}`,
                label: "Year",
            },
            marks: [
                Plot.line(
                        sums,
                        {
                            x: "reporting_year",
                            y: (d) => d.hours,
                            curve: "catmull-rom",
                            strokeWidth: 3,
                            stroke: '#1f4299',
                        }
                ),
                Plot.dot(
                        sums,
                        {
                            x: "reporting_year",
                            y: (d) => d.hours,
                            r: 8,
                            title: (d) => `${d.reporting_year} - ${utils.formatNumber(d.hours)} hours`,
                            tip: true,
                            stroke: '#1f4299',
                            fill: '#971f99',
                        }
                ),
            ]
        })
    };

    const div = document.getElementById("plot-industry-all-time");
    const response = await fetch(div.attributes["data-uri"].value);
    const rect = div.getBoundingClientRect()
    if (response.ok) {
        div.appendChild(PlotSpillsByIndustryAllTime(await response.json(), rect.width, rect.height))
    }
</script>


<script type="module">

    import * as Plot from "/assets/js/plot-0.6.17/plot.esm.js";
    import * as utils from "/assets/js/utils.js"


    const PlotRainfallByYear = (data, width, height) => {
        return Plot.plot({
            width: width,
            height: height,
            y: {
                grid: true,
                label: "Rainfall as % of long term ↑",
                domain: [80,120]
            },
            color: {
                legend: true
            },
            x: {
                grid: false,
                domain: [2020, 2021, 2022, 2023, 2024, 2025, 2026],
                tickFormat: d => `${d}`,
            },
            marks: [
                Plot.ruleY([100], {stroke: "red"}),
                Plot.line(
                        data,
                        {
                            x: "y",
                            y: "v",
                            curve: "catmull-rom",
                            strokeWidth: 3,
                            tip: true,
                            opacity: 0.7,
                        }
                ),
                Plot.dot(data, {
                    x: "y",
                    y: "v",
                    r: 6,
                })
            ]
        })
    };

    const divr = document.getElementById("plot-rainfall-totals");
    const rectr = divr.getBoundingClientRect()
    const rainfall = [
        {"y": 2020, "v": 114},
        {"y": 2021, "v": 93},
        {"y": 2022, "v": 90},
        {"y": 2023, "v": 111},
        {"y": 2024, "v": 107},
        {"y": 2025, "v": 90},
    ]
    divr.appendChild(PlotRainfallByYear(rainfall, rectr.width, rectr.height))

</script>



<div class="container-fluid py-5">
    <div class="row justify-content-md-center g-4 sewage-columns-equal-height">
        <div class="col-md-5">
            <div class="position-relative">
                <img alt="A stylised map of England and Wales showing CSO locations" class="img-fluid rounded "
                     src="/assets/images/top-of-the-poops-cso-2023-web-fs8.png"/>
            </div>
        </div>
        <div class="col-md-4 align-top">
            <div class="card border-0">
                <div class="card-body">
                    <h2 class="card-title fw-bold text-danger mb-3">A Petri Dish for E.Coli</h2>

                    <p class="card-text">Here are all the {{> g/cso }}s in England, Wales & Scotland that 'overflowed' in {{ year }}
                        - dumping raw or minimally treated sewage into fragile chalk streams, rivers, onto beaches and into shellfish
                        areas.</p>
                    <p class="card-text">Each colour represents a different Water Company, the size of each dot relates
                        to how long each
                        overflow was polluting - where the monitoring is disabled we show a medium-sized dot.</p>

                    <p class="card-text">You might think that putting sewage into a river is something that never happens - who would do that? - but sadly
                    its something that happens hundreds or thousands of times a day. The Environment Agency does publish this data, in complex formats
                    that are hard to understand. We try to arrange this data, so that you can see how your local area, and places that you care about,
                    are affected. </p>

                    <p class="card-text">Have a look on this page to see what types of places are affected, or find your local constituency, or your water company,
                        using the menus, and see how your local area is affected. Almost everywhere in the country is affected. </p>

                    <p class="card-text">We use two sources of information - annual reports, published each April, which give figures for the previous year, and a real-time
                    data stream. As there are differences in the naming of {{>g/cso}}s we can't show them together mostly.</p>

                    <p class="card-text"><small class="text-muted">The figures, supplied by the water companies
                        themselves, understate the problem, as the data is
                        poorly collected by the Water Companies, with monitoring defective or in many cases completely
                        absent.</small></p>

                    <div class="alert alert-info p-3 mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <span class="badge bg-primary fs-5">{{numberFormat summary.count.start}}</span>
                            <h5 class="ms-2">{{> g/cso }}s are overflowing right now</h5>
                        </div>
                        <a href="/now" class="btn btn-danger">See live sewage overflows</a>
                    </div>

                    <div class="gap-2 mb-4">
                        {{> components/share-social share}}
                    </div>

                    {{> chunks/plea }}
                </div>
            </div>
        </div>
    </div>
</div>

